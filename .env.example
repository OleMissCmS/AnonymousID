# -----------------------------
# Crypto configuration
# -----------------------------
# HMAC-SHA256 key for deterministic lookup. Either:
# - base64-encoded raw bytes (non-empty when decoded), or
# - any UTF-8 string / passphrase (used as raw bytes).
HMAC_SECRET="your-secret"

# AES-256-GCM key material. Any of:
# - base64 that decodes to exactly 32 bytes, or
# - 64 hex characters (32 bytes), or
# - any UTF-8 string (SHA-256 hashed to 32 bytes).
ENC_KEY="your-encryption-secret"

# -----------------------------
# Upstash Redis (REST) configuration
# -----------------------------
# Server-only URL/token used by API route for GET + SET NX.
AID_KV_REST_API_URL="https://YOUR_INSTANCE.upstash.io"
AID_KV_REST_API_TOKEN="YOUR_UPSTASH_REST_TOKEN"

# Optional read-only token (not required by current app code).
AID_KV_REST_API_READ_ONLY_TOKEN="YOUR_UPSTASH_READ_ONLY_TOKEN"

